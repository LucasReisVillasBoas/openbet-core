{
  "name": "openbet-core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "White-label betting platform framework",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "clean": "turbo clean && rm -rf node_modules",
    "validate": "tsx scripts/validate-configs.ts",
    "test:theme": "tsx scripts/test-theme-engine.ts",
    "lint": "eslint packages/*/src apps/*/app apps/*/components apps/*/lib",
    "format": "prettier --write \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/app/**/*.{ts,tsx}\" \"apps/*/components/**/*.{ts,tsx}\" \"apps/*/lib/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"packages/*/src/**/*.{ts,tsx}\" \"apps/*/app/**/*.{ts,tsx}\" \"apps/*/components/**/*.{ts,tsx}\" \"apps/*/lib/**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "@openbet/config-schema": "workspace:*",
    "@openbet/theme-engine": "workspace:*",
    "@types/jsdom": "^21.1.7",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^25.0.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0"
}
