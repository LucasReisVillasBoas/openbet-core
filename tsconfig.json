{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    "noEmit": true
  },
  "include": [
    "packages/config-schema/src/**/*",
    "packages/theme-engine/src/**/*",
    "packages/ui/src/**/*"
  ]
}
